rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global safety validators
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Task Validation
    function isValidTask(data) {
      return data.id is string && data.id.size() <= 100 &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             data.status in ['todo', 'in_progress', 'done'] &&
             data.priority in ['low', 'medium', 'high', 'urgent'] &&
             data.assignedUsers is list && data.assignedUsers.size() <= 20 &&
             data.dueDate is string && data.dueDate.size() <= 30 &&
             data.createdAt is string && data.createdAt.size() <= 50;
    }

    // Message Validation
    function isValidMessage(data) {
      return data.id is string && data.id.size() <= 100 &&
             data.taskId is string && data.taskId.size() <= 100 &&
             data.senderId is string && data.senderId.size() <= 100 &&
             data.senderName is string && data.senderName.size() <= 100 &&
             data.messageText is string && data.messageText.size() <= 10000 &&
             data.timestamp is string && data.timestamp.size() <= 50;
    }

    // Notification Validation
    function isValidNotification(data) {
      return data.id is string && data.id.size() <= 100 &&
             data.title is string && data.title.size() <= 150 &&
             data.message is string && data.message.size() <= 1000 &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             data.read is bool &&
             data.type in ['info', 'success', 'warning', 'urgent'];
    }

    // Match rules for Tasks
    match /tasks/{taskId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(request.resource.data);
      allow update: if isSignedIn() && isValidId(taskId) && isValidTask(request.resource.data);
      allow delete: if isSignedIn() && isValidId(taskId);
    }

    // Match rules for Task Chat Messages
    match /tasks/{taskId}/messages/{messageId} {
      allow read, list: if isSignedIn() && isValidId(taskId);
      allow create: if isSignedIn() && isValidId(taskId) && isValidId(messageId) && isValidMessage(request.resource.data);
      allow update: if isSignedIn() && isValidId(taskId) && isValidId(messageId) && isValidMessage(request.resource.data);
      allow delete: if isSignedIn() && isValidId(taskId) && isValidId(messageId);
    }

    // Match rules for Notifications
    match /notifications/{notifId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(notifId) && isValidNotification(request.resource.data);
      allow update: if isSignedIn() && isValidId(notifId) && isValidNotification(request.resource.data);
      allow delete: if isSignedIn() && isValidId(notifId);
    }
  }
}
